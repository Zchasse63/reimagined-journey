---
/**
 * Native-HTML accordion (uses <details> + <summary> — no JS, no React).
 * Renders an FAQ list and is paired with FAQPage JSON-LD emitted by the
 * page that includes it.
 */
interface Props {
  faqs: Array<{ question: string; answer: string }>;
  headingLevel?: 'h2' | 'h3';
}

const { faqs, headingLevel = 'h2' } = Astro.props;
const HeadingTag = headingLevel;
---

{faqs.length > 0 && (
  <section class="not-prose my-10">
    <HeadingTag class={headingLevel === 'h2' ? 'text-2xl md:text-3xl font-bold text-slate-900 mb-6' : 'text-xl font-semibold text-slate-900 mb-4'}>
      Frequently asked questions
    </HeadingTag>
    <div class="space-y-3">
      {faqs.map((faq) => (
        <details class="group bg-white border border-slate-200 rounded-xl p-5 hover:border-slate-300 transition-colors">
          <summary class="cursor-pointer font-semibold text-slate-900 list-none flex justify-between items-start gap-4">
            <span>{faq.question}</span>
            <span class="text-primary-600 shrink-0 transition-transform group-open:rotate-45 text-2xl leading-none">+</span>
          </summary>
          <p class="mt-3 text-slate-700 leading-relaxed">{faq.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
