---
interface Props {
  label: string;
  variant?: 'default' | 'eco' | 'safe';
}

const { label, variant = 'default' } = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-slate-100 text-slate-700 border-slate-200',
  eco: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  safe: 'bg-blue-50 text-blue-700 border-blue-200',
};
---

<span
  class={`inline-flex items-center px-2 py-0.5 rounded-md border text-xs font-medium ${variantClasses[variant]}`}
>
  {label}
</span>
