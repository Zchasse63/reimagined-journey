---
import { getCollection, getEntry } from 'astro:content';
import ArticleLayout from '@/layouts/ArticleLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const guides = await getCollection('guides');
  return guides.map((g) => ({
    // entry.slug is auto-derived from the filename in Astro 5 (e.g.
    // `foodservice-clamshells.mdx` → "foodservice-clamshells").
    params: { slug: g.slug },
    props: { entry: g },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const data = entry.data;
---

<ArticleLayout
  title={data.title}
  description={data.description}
  slug={entry.slug}
  publishedDate={data.publishedDate}
  updatedDate={data.updatedDate}
  type={data.type}
  heroEmoji={data.heroEmoji}
  tableOfContents={data.tableOfContents}
  faqs={data.faqs}
  relatedCategories={data.relatedCategories}
  relatedGuides={data.relatedGuides}
  headings={headings}
>
  <Content />
</ArticleLayout>
